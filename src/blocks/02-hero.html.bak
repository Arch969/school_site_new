<section class="ku-hero" id="top">
  <div class="ku-hero__grad"></div>
  <div class="ku-hero__grid"></div>
  <div class="ku-hero__orb ku-hero__orb--blue"></div>
  <div class="ku-hero__orb ku-hero__orb--red"></div>

  <div class="ku-hero__container">
    <div class="ku-hero__layout">
      <div class="ku-hero__left">
        <div class="ku-hero__badge">
          <span class="ku-hero__badge-dot"></span>
          Набор открыт — осталось 12 мест
        </div>

        <h1 class="ku-hero__title">
          Ваш ребёнок<br>
          <span class="ku-hero__underline-wrap">
            <span class="ku-hero__blue">создаст</span>
            <svg class="ku-hero__underline" viewBox="0 0 100 8" preserveAspectRatio="none" aria-hidden="true">
              <path d="M2 6C25 2 75 2 98 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"></path>
            </svg>
          </span>
          цифровое<br>
          <span class="ku-hero__gradient-text">будущее</span>
        </h1>

        <p class="ku-hero__text">
          Онлайн-школа программирования для детей.
          Индивидуальные занятия c преподавателем для детей от 6 до 16 лет.
          Реальные проекты уже с первого урока.
        </p>

        <div class="ku-hero__actions">
          <a href="#trial-form" data-scroll class="ku-btn ku-btn--primary">
            Записаться бесплатно
            <span class="ku-btn__arrow">→</span>
          </a>
          <a href="#courses-real" data-scroll class="ku-btn ku-btn--secondary">
            Посмотреть курсы
          </a>
        </div>

        <div class="ku-hero__meta">
          <div class="ku-hero__meta-item">🎓 Бесплатный пробный урок</div>
          <div class="ku-hero__meta-item">👨‍🏫 Занятия 1 на 1</div>
          <div class="ku-hero__meta-item">🏆 1000+ учеников</div>
          <div class="ku-hero__meta-item">⭐ Рейтинг 4.9/5</div>
        </div>
      </div>

      <div class="ku-hero__right" id="kuHeroVisual">
        <div class="ku-visual">
          <svg class="ku-visual__rings" viewBox="0 0 500 500" fill="none" aria-hidden="true">
            <ellipse cx="250" cy="250" rx="210" ry="80" stroke="rgba(59,130,246,0.14)" stroke-width="1" transform="rotate(-15 250 250)" />
            <ellipse cx="250" cy="250" rx="155" ry="60" stroke="rgba(239,68,68,0.12)" stroke-width="1" transform="rotate(25 250 250)" />
            <ellipse cx="250" cy="250" rx="100" ry="40" stroke="rgba(6,182,212,0.16)" stroke-width="1" transform="rotate(-40 250 250)" />
            <circle cx="120" cy="150" r="5" fill="#3b82f6" />
            <circle cx="310" cy="165" r="5" fill="#3b82f6" />
            <circle cx="460" cy="280" r="4" fill="#ef4444" />
            <circle cx="175" cy="370" r="4" fill="rgba(59,130,246,.7)" />
            <circle cx="430" cy="400" r="3.5" fill="rgba(239,68,68,.7)" />
          </svg>

          <div class="ku-hero-main">
            <img src="media/hero3.png" alt="Дети изучают программирование онлайн" width="627" height="627" loading="eager" fetchpriority="high">
          </div>

          <div class="ku-hero-icon ku-hero-icon--python">
            <img src="media/courses_logo_hero/Python.png" alt="Python" width="256" height="256">
          </div>

          <div class="ku-hero-icon ku-hero-icon--roblox">
            <img src="media/courses_logo_hero/Roblox.png" alt="Roblox" width="314" height="314">
          </div>

          <div class="ku-hero-icon ku-hero-icon--scratch">
            <img src="media/courses_logo_hero/Scratch.png" alt="Scratch" width="314" height="314">
          </div>

          <div class="ku-hero-icon ku-hero-icon--ai">
            <img src="media/courses_logo_hero/AI.png" alt="AI" width="314" height="314">
          </div>

          <div class="ku-hero-icon ku-hero-icon--three-d">
            <img src="media/courses_logo_hero/3D.png" alt="3D" width="314" height="314">
          </div>

          <div class="ku-hero-icon ku-hero-icon--design">
            <img src="media/courses_logo_hero/design.png" alt="Design" width="314" height="314">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="ku-hero__wave">
    <svg viewBox="0 0 1440 50" fill="none">
      <path d="M0 50L1440 50L1440 20C1100 50 900 5 600 18C300 31 150 5 0 20Z" fill="hsl(214 60% 97%)"></path>
    </svg>
  </div>
</section>
